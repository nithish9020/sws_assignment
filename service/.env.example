# ----------------------------------------------------------------------------
# Service environment variables. Copy to `.env` and fill in real values.
#   cp .env.example .env
# ----------------------------------------------------------------------------

# HTTP server
PORT=4000
# Comma-separated list of allowed origins for CORS (Expo dev + web).
# Use * during local dev only.
CORS_ORIGIN=*

# Neon Postgres connection string (pooled). Get this from the Neon console:
#   Dashboard -> your project -> Connection Details -> "Pooled connection"
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Storage provider: "cloudinary" (default) or "local" (dev-only filesystem).
STORAGE_PROVIDER=cloudinary

# --- Cloudinary (required when STORAGE_PROVIDER=cloudinary) ---
# From Cloudinary console -> Dashboard -> Product Environment Credentials.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Folder uploaded PDFs are stored under.
CLOUDINARY_FOLDER=docmanager

# --- Local disk (only used when STORAGE_PROVIDER=local) ---
# Files are written here and served from /uploads. NOT persistent on Render.
LOCAL_UPLOAD_DIR=./uploads
