{
  "name": "docmanager",
  "version": "0.1.0",
  "private": true,
  "description": "Document Management Mobile App — Expo (app) + Bun/Express (service) + shared Zod contracts",
  "workspaces": [
    "shared",
    "service",
    "app"
  ],
  "scripts": {
    "dev:service": "bun run --cwd service dev",
    "dev:app": "bun run --cwd app start",
    "build:shared": "bun run --cwd shared build",
    "typecheck": "bun run --cwd shared typecheck && bun run --cwd service typecheck"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
