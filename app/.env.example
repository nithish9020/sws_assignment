# Expo environment variables (prefix EXPO_PUBLIC_ to expose to the JS bundle).
# Copy to .env.local for local dev:  cp .env.example .env.local

# URL of the running service. Use your machine's LAN IP when testing on a device/Expo Go.
# Example: http://192.168.1.42:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
